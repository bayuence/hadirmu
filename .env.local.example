# Supabase Configuration
# Dapatkan credentials ini dari Supabase Dashboard > Project Settings > API

# URL Supabase Project Anda
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Anon/Public Key (aman untuk client-side)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================
# CARA SETUP:
# ============================================
# 1. Copy file ini menjadi .env.local
# 2. Ganti nilai di atas dengan credentials dari Supabase Dashboard
# 3. Restart dev server (pnpm dev)
# ============================================
